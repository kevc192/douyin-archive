# Hosts can override these Docker paths with mounted locations.
DATABASE_URL=sqlite:////app/data/app.db
DOWNLOAD_ROOT=/app/downloads
# Cron expression: minute hour day-of-month month day-of-week
SYNC_CRON=15 */6 * * *
# Keep this false unless you have a legal basis to archive age-restricted material.
ALLOW_AGE_RESTRICTED=false
# Chrome started by the user with --remote-debugging-port=9222.
BROWSER_CDP_URL=http://host.docker.internal:9222
PROFILE_SCROLL_ROUNDS=18
# Optional: set a reachable mirror when Docker Hub is unavailable on your network.
# PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
